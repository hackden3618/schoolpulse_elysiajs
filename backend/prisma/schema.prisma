generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum SubscriptionStatus {
    trial
    active
    cancelled
    suspended
    defaulted
    terminated
}

enum SubscriptionType {
    free
    monthly
    termly
    yearly
}

enum UserStatus {
    active
    on_leave
    suspended
    defaulted
    terminated
}

model School {
    id                    String             @id @default(uuid()) @db.Uuid
    schoolName            String
    schoolPhone           String
    schoolAddress         String?
    schoolLogo            String?
    schoolEmail           String?
    schoolWebsite         String?
    postOffice            String?
    subscriptionStatus    SubscriptionStatus @default(trial)
    subscriptionType      SubscriptionType   @default(free)
    subscriptionStartDate DateTime?          @db.Timestamptz
    subscriptionEndDate   DateTime?          @db.Timestamptz
    createdAt             DateTime           @default(now()) @db.Timestamptz
    updatedAt             DateTime           @updatedAt @db.Timestamptz

    memberships SchoolMembership[]
    streams     Stream[]
    classes     Class[]
    students    Student[]
}

model User {
    id             String     @id @default(uuid()) @db.Uuid
    firstName      String
    secondName     String?
    lastName       String?
    phone          String     @unique
    hashedPassword String
    email          String?    @unique
    status         UserStatus @default(active)
    createdAt      DateTime   @default(now()) @db.Timestamptz
    updatedAt      DateTime   @updatedAt @db.Timestamptz

    memberships SchoolMembership[]
    guardians   StudentGuardian[]
}

model Role {
    id          String   @id @default(uuid()) @db.Uuid
    name        String   @unique
    description String?
    createdAt   DateTime @default(now()) @db.Timestamptz
    updatedAt   DateTime @updatedAt @db.Timestamptz

    membershipRoles SchoolMembershipRole[]
}

model SchoolMembership {
    id        String   @id @default(uuid()) @db.Uuid
    schoolId  String   @db.Uuid
    userId    String   @db.Uuid
    createdAt DateTime @default(now()) @db.Timestamptz
    updatedAt DateTime @updatedAt @db.Timestamptz

    school School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
    user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
    roles  SchoolMembershipRole[]

    @@unique([schoolId, userId])
}

model SchoolMembershipRole {
    id           String @id @default(uuid()) @db.Uuid
    membershipId String @db.Uuid
    roleId       String @db.Uuid

    membership SchoolMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
    role       Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

    @@unique([membershipId, roleId])
}

model Stream {
    id         String   @id @default(uuid()) @db.Uuid
    streamName String
    schoolId   String   @db.Uuid
    createdAt  DateTime @default(now()) @db.Timestamptz
    updatedAt  DateTime @updatedAt @db.Timestamptz

    school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Class {
    id           String   @id @default(uuid()) @db.Uuid
    className    String
    classTeacher String
    classLevel   String
    schoolId     String   @db.Uuid
    createdAt    DateTime @default(now()) @db.Timestamptz
    updatedAt    DateTime @updatedAt @db.Timestamptz

    school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
    students Student[]
}

model Student {
    id              String   @id @default(uuid()) @db.Uuid
    dateOfBirth     DateTime @db.Date
    admissionNumber String
    classId         String   @db.Uuid
    schoolId        String   @db.Uuid
    firstName       String
    secondName      String?
    lastName        String
    createdAt       DateTime @default(now()) @db.Timestamptz
    updatedAt       DateTime @updatedAt @db.Timestamptz

    class     Class             @relation(fields: [classId], references: [id])
    school    School            @relation(fields: [schoolId], references: [id])
    guardians StudentGuardian[]
}

model StudentGuardian {
    relationshipId String @id @default(uuid()) @db.Uuid
    studentId      String @db.Uuid
    guardianId     String @db.Uuid
    relationship   String

    student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
    guardian User    @relation(fields: [guardianId], references: [id], onDelete: Cascade)

    @@unique([studentId, guardianId])
}
